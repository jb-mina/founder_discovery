# Public-facing analytics. If unset, PostHog is fully disabled (dev-friendly).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Anthropic Claude API key (used by all agents). Required.
ANTHROPIC_API_KEY=

# OpenRouter (Reality Check only — vendor diversification across OpenAI / Google / Perplexity).
# Required for the panel review (RC) feature when persona is configured to use a non-Anthropic model.
# Configure dashboard logging-off + zero data retention before use (CLAUDE.md §7).
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=https://my0to1.com
OPENROUTER_X_TITLE=My 0to1 Reality Check
